# Copy this file to .env and fill in your keys

# Required: Get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required for LangSmith tracing (get from smith.langchain.com)
LANGSMITH_API_KEY=ls__your-key-here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=ai-learning-guide

# Optional: OpenAI (if you want to compare models)
# OPENAI_API_KEY=sk-your-key-here

# Optional: Pinecone (cloud vector DB for production)
# PINECONE_API_KEY=your-key-here
# PINECONE_INDEX=your-index-name
